      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Tajawal:wght@400;500;700;900&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  :root {\n    --bg-primary: #0a0f1e;\n    --bg-glass: rgba(17, 24, 39, 0.8);\n    --emerald-400: #4ade80;\n    --emerald-500: #10b981;\n    --text-primary: #f1f5f9;\n    --text-secondary: #94a3b8;\n    --border-glass: rgba(255, 255, 255, 0.1);\n  }\n\n  body {\n    font-family: 'Tajawal', sans-serif;\n    background-color: var(--bg-primary);\n    color: var(--text-primary);\n    direction: rtl;\n    margin: 0;\n    padding: 2rem;\n  }\n\n  .glass-panel {\n    background: var(--bg-glass);\n    backdrop-filter: blur(12px);\n    border: 1px solid var(--border-glass);\n    border-radius: 1rem;\n  }\n\n  .custom-tooltip {\n    visibility: hidden;\n    opacity: 0;\n    transition: opacity 0.3s;\n  }\n\n  .has-tooltip:hover .custom-tooltip {\n    visibility: visible;\n    opacity: 1;\n  }\n</style>\n\n<div class=\"max-w-7xl mx-auto space-y-8\" data-kid=\"1\">\n  \n  <header class=\"flex items-center justify-between\" data-kid=\"2\">\n    <div class=\"flex items-center gap-4\" data-kid=\"3\">\n      <div class=\"w-12 h-12 bg-emerald-500/20 text-emerald-400 flex items-center justify-center rounded-xl border border-emerald-500/30\" data-kid=\"4\">\n        <i class=\"ti ti-users text-2xl\" data-kid=\"5\"></i>\n      </div>\n      <div data-kid=\"6\">\n        <h1 class=\"text-2xl font-black\" data-kid=\"7\">بوابة الأولياء</h1>\n        <p class=\"text-sm text-slate-400\" data-kid=\"8\">تتبع دخول أولياء الأمور والنشاط اليومي</p>\n      </div>\n    </div>\n    <div class=\"flex items-center gap-3\" data-kid=\"9\">\n      <button class=\"px-4 py-2 bg-slate-800 hover:bg-slate-700 text-white rounded-lg flex items-center gap-2 transition-colors border border-slate-700\" data-kid=\"10\">\n        <i class=\"ti ti-refresh text-lg\" data-kid=\"11\"></i>\n        <span data-kid=\"12\">تحديث البيانات</span>\n      </button>\n      <button class=\"px-4 py-2 bg-emerald-600 hover:bg-emerald-500 text-white rounded-lg flex items-center gap-2 transition-colors font-bold\" data-kid=\"13\">\n        <i class=\"ti ti-download text-lg\" data-kid=\"14\"></i>\n        <span data-kid=\"15\">تصدير التقرير</span>\n      </button>\n    </div>\n  </header>\n\n  \n  <div class=\"glass-panel p-6 bg-emerald-500/5 border-emerald-500/20 flex items-center gap-6\" data-kid=\"16\">\n    <div class=\"w-14 h-14 bg-emerald-500 text-white flex items-center justify-center rounded-full shadow-lg shadow-emerald-500/20 shrink-0\" data-kid=\"17\">\n      <i class=\"ti ti-tool text-3xl\" data-kid=\"18\"></i>\n    </div>\n    <div data-kid=\"19\">\n      <h2 class=\"text-lg font-bold text-emerald-400\" data-kid=\"20\">تحسين تجربة العرض: معالجة الأسماء الطويلة</h2>\n      <p class=\"text-slate-300 mt-1 max-w-3xl\" data-kid=\"21\">\n        تم حل مشكلة تداخل الأسماء في الجدول عبر تطبيق تقنية <strong data-kid=\"22\">الاختصار الذكي (Truncation)</strong> مع <strong data-kid=\"23\">تلميحات الأدوات (Tooltips)</strong>. \n        يضمن هذا بقاء تصميم الجدول ثابتاً ومنظماً حتى مع الأسماء التي تتجاوز الطول المعتاد.\n      </p>\n    </div>\n  </div>\n\n  \n  <div class=\"grid grid-cols-1 md:grid-cols-4 gap-4\" data-kid=\"24\">\n    <div class=\"glass-panel p-5 flex items-center gap-4\" data-kid=\"25\">\n      <div class=\"w-12 h-12 rounded-lg bg-blue-500/10 text-blue-400 flex items-center justify-center\" data-kid=\"26\">\n        <i class=\"ti ti-users-group text-2xl\" data-kid=\"27\"></i>\n      </div>\n      <div data-kid=\"28\">\n        <div class=\"text-2xl font-black\" data-kid=\"29\">124</div>\n        <div class=\"text-xs text-slate-400\" data-kid=\"30\">إجمالي الأولياء</div>\n      </div>\n    </div>\n    <div class=\"glass-panel p-5 flex items-center gap-4 border-emerald-500/20\" data-kid=\"31\">\n      <div class=\"w-12 h-12 rounded-lg bg-emerald-500/10 text-emerald-400 flex items-center justify-center\" data-kid=\"32\">\n        <i class=\"ti ti-user-check text-2xl\" data-kid=\"33\"></i>\n      </div>\n      <div data-kid=\"34\">\n        <div class=\"text-2xl font-black text-emerald-400\" data-kid=\"35\">86</div>\n        <div class=\"text-xs text-slate-400\" data-kid=\"36\">نشط اليوم</div>\n      </div>\n    </div>\n    <div class=\"glass-panel p-5 flex items-center gap-4\" data-kid=\"37\">\n      <div class=\"w-12 h-12 rounded-lg bg-amber-500/10 text-amber-400 flex items-center justify-center\" data-kid=\"38\">\n        <i class=\"ti ti-clock text-2xl\" data-kid=\"39\"></i>\n      </div>\n      <div data-kid=\"40\">\n        <div class=\"text-2xl font-black\" data-kid=\"41\">12</div>\n        <div class=\"text-xs text-slate-400\" data-kid=\"42\">نشط مؤخراً</div>\n      </div>\n    </div>\n    <div class=\"glass-panel p-5 flex items-center gap-4\" data-kid=\"43\">\n      <div class=\"w-12 h-12 rounded-lg bg-red-500/10 text-red-400 flex items-center justify-center\" data-kid=\"44\">\n        <i class=\"ti ti-user-x text-2xl\" data-kid=\"45\"></i>\n      </div>\n      <div data-kid=\"46\">\n        <div class=\"text-2xl font-black\" data-kid=\"47\">26</div>\n        <div class=\"text-xs text-slate-400\" data-kid=\"48\">خامل</div>\n      </div>\n    </div>\n  </div>\n\n  \n  <div class=\"glass-panel overflow-hidden border-slate-800\" data-kid=\"49\">\n    <div class=\"p-4 border-b border-slate-800 flex items-center justify-between bg-white/5\" data-kid=\"50\">\n      <div class=\"relative w-96\" data-kid=\"51\">\n        <i class=\"ti ti-search absolute right-3 top-1/2 -translate-y-1/2 text-slate-500\" data-kid=\"52\"></i>\n        <input type=\"text\" placeholder=\"ابحث باسم الولي أو الطالب...\" class=\"w-full bg-slate-900 border border-slate-700 rounded-lg py-2 pr-10 pl-4 text-sm focus:outline-none focus:border-emerald-500 transition-colors\" data-kid=\"53\">\n      </div>\n      <div class=\"flex gap-2\" data-kid=\"54\">\n        <select class=\"bg-slate-900 border border-slate-700 rounded-lg py-2 px-4 text-sm focus:outline-none focus:border-emerald-500\" data-kid=\"55\">\n          <option data-kid=\"56\">كل الحالات</option>\n          <option data-kid=\"57\">نشط اليوم</option>\n          <option data-kid=\"58\">خامل</option>\n        </select>\n      </div>\n    </div>\n\n    <table class=\"w-full text-right border-collapse\" data-kid=\"59\">\n      <thead data-kid=\"60\">\n        <tr class=\"bg-slate-900/50 text-slate-400 text-xs uppercase tracking-wider\" data-kid=\"61\">\n          <th class=\"px-6 py-4 font-bold border-b border-slate-800\" data-kid=\"62\">ولي الأمر</th>\n          <th class=\"px-6 py-4 font-bold border-b border-slate-800\" data-kid=\"63\">الأبناء (تم إصلاح العرض)</th>\n          <th class=\"px-6 py-4 font-bold border-b border-slate-800\" data-kid=\"64\">رقم الهاتف</th>\n          <th class=\"px-6 py-4 font-bold border-b border-slate-800\" data-kid=\"65\">الحالة</th>\n          <th class=\"px-6 py-4 font-bold border-b border-slate-800\" data-kid=\"66\">آخر دخول</th>\n          <th class=\"px-6 py-4 font-bold border-b border-slate-800 text-center\" data-kid=\"67\">الإجراءات</th>\n        </tr>\n      </thead>\n      <tbody class=\"divide-y divide-slate-800/50\" data-kid=\"68\">\n        \n        <tr class=\"hover:bg-white/5 transition-colors group\" data-kid=\"69\">\n          <td class=\"px-6 py-4\" data-kid=\"70\">\n            <div class=\"font-bold\" data-kid=\"71\">محمد عبد الرحمن</div>\n            <div class=\"text-xs text-slate-500\" data-kid=\"72\">@m_rahman</div>\n          </td>\n          <td class=\"px-6 py-4\" data-kid=\"73\">\n            <div class=\"flex flex-wrap gap-2\" data-kid=\"74\">\n              <span class=\"bg-emerald-500/10 text-emerald-400 border border-emerald-500/20 px-2 py-1 rounded text-xs font-medium\" data-kid=\"75\">أحمد</span>\n              \n              <div class=\"relative has-tooltip\" data-kid=\"76\">\n                <span class=\"bg-emerald-500/10 text-emerald-400 border border-emerald-500/20 px-2 py-1 rounded text-xs font-medium max-w-[120px] block truncate cursor-help\" data-kid=\"77\">\n                  عبد الرحمن محمد علي القحطاني الشمري\n                </span>\n                \n                <div class=\"custom-tooltip absolute bottom-full right-0 mb-2 w-max max-w-[200px] bg-slate-800 border border-emerald-500/30 text-white p-3 rounded-lg shadow-2xl z-50 text-xs leading-relaxed pointer-events-none\" data-kid=\"78\">\n                  <div class=\"text-emerald-400 font-bold mb-1\" data-kid=\"79\">الاسم الكامل:</div>\n                  عبد الرحمن محمد علي القحطاني الشمري\n                </div>\n              </div>\n            </div>\n          </td>\n          <td class=\"px-6 py-4 text-sm font-mono text-slate-400\" data-kid=\"80\">050XXXXX12</td>\n          <td class=\"px-6 py-4\" data-kid=\"81\">\n            <span class=\"inline-flex items-center gap-1.5 px-2.5 py-0.5 rounded-full text-xs font-bold bg-emerald-500/20 text-emerald-400\" data-kid=\"82\">\n              <span class=\"w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse\" data-kid=\"83\"></span>\n              نشط الآن\n            </span>\n          </td>\n          <td class=\"px-6 py-4\" data-kid=\"84\">\n            <div class=\"text-sm\" data-kid=\"85\">اليوم، 10:45 ص</div>\n          </td>\n          <td class=\"px-6 py-4 text-center\" data-kid=\"86\">\n            <button class=\"text-slate-400 hover:text-emerald-400 transition-colors\" data-kid=\"87\">\n              <i class=\"ti ti-eye text-lg\" data-kid=\"88\"></i>\n            </button>\n          </td>\n        </tr>\n\n        \n        <tr class=\"hover:bg-white/5 transition-colors\" data-kid=\"89\">\n          <td class=\"px-6 py-4\" data-kid=\"90\">\n            <div class=\"font-bold\" data-kid=\"91\">سارة الأحمد</div>\n            <div class=\"text-xs text-slate-500\" data-kid=\"92\">@s_ahmed</div>\n          </td>\n