      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Tajawal:wght@400;500;700;800;900&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  :root {\n    --bg-deep: #050810;\n    --bg-card: #0b1120;\n    --border-subtle: #1e293b;\n    --text-main: #f8fafc;\n    --text-muted: #94a3b8;\n    --accent: #38bdf8;\n  }\n\n  body {\n    background-color: var(--bg-deep);\n    color: var(--text-main);\n    font-family: 'Tajawal', sans-serif;\n    margin: 0;\n    padding: 0;\n    direction: rtl;\n  }\n\n  .minimal-card {\n    background-color: var(--bg-card);\n    border: 1px solid var(--border-subtle);\n    border-radius: 1.25rem;\n    transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);\n  }\n\n  .minimal-card:hover {\n    border-color: var(--accent);\n    background-color: #0f172a;\n  }\n\n  .name-wrapper {\n    word-break: break-word;\n    overflow-wrap: break-word;\n    line-height: 1.4;\n  }\n\n  .btn-minimal {\n    background-color: rgba(56, 189, 248, 0.1);\n    color: var(--accent);\n    border: 1px solid rgba(56, 189, 248, 0.2);\n    transition: all 0.2s;\n  }\n\n  .btn-minimal:hover {\n    background-color: var(--accent);\n    color: var(--bg-deep);\n  }\n</style>\n\n<div class=\"min-h-screen py-12 px-6 max-w-2xl mx-auto\" data-kid=\"1\">\n  \n  <div class=\"mb-12 text-center\" data-kid=\"2\">\n    <h1 class=\"text-2xl font-black text-white mb-2\" data-kid=\"3\">متابعة الأبناء</h1>\n    <div class=\"w-12 h-1 bg-(--accent) mx-auto rounded-full opacity-50\" data-kid=\"4\"></div>\n  </div>\n\n  <div class=\"space-y-4\" data-kid=\"5\">\n    \n    <div class=\"minimal-card p-5 flex items-center gap-5\" data-kid=\"6\">\n      <div class=\"w-14 h-14 rounded-full bg-slate-800 flex items-center justify-center border border-(--border-subtle) shrink-0\" data-kid=\"7\">\n        <i class=\"ti ti-user text-2xl text-slate-400\" data-kid=\"8\"></i>\n      </div>\n      \n      <div class=\"flex-1 min-w-0\" data-kid=\"9\">\n        <h2 class=\"text-lg font-bold text-(--text-main) name-wrapper\" data-kid=\"10\">\n          عبد الرحمن بن محمد بن علي بن عثمان آل شيخ التميمي المازني\n        </h2>\n        <p class=\"text-xs text-(--text-muted) mt-1\" data-kid=\"11\">المستوى الرابع • سورة الكهف</p>\n      </div>\n\n      <button class=\"btn-minimal px-4 py-2 rounded-lg text-sm font-bold shrink-0\" data-kid=\"12\">\n        التفاصيل\n      </button>\n    </div>\n\n    \n    <div class=\"minimal-card p-5 flex items-center gap-5\" data-kid=\"13\">\n      <div class=\"w-14 h-14 rounded-full bg-slate-800 flex items-center justify-center border border-(--border-subtle) shrink-0\" data-kid=\"14\">\n        <i class=\"ti ti-user text-2xl text-slate-400\" data-kid=\"15\"></i>\n      </div>\n      \n      <div class=\"flex-1 min-w-0\" data-kid=\"16\">\n        <h2 class=\"text-lg font-bold text-(--text-main) name-wrapper\" data-kid=\"17\">\n          أحمد بن صالح\n        </h2>\n        <p class=\"text-xs text-(--text-muted) mt-1\" data-kid=\"18\">المستوى الثاني • سورة مريم</p>\n      </div>\n\n      <button class=\"btn-minimal px-4 py-2 rounded-lg text-sm font-bold shrink-0\" data-kid=\"19\">\n        التفاصيل\n      </button>\n    </div>\n\n    \n    <div class=\"minimal-card p-5 flex items-center gap-5\" data-kid=\"20\">\n      <div class=\"w-14 h-14 rounded-full bg-slate-800 flex items-center justify-center border border-(--border-subtle) shrink-0\" data-kid=\"21\">\n        <i class=\"ti ti-user text-2xl text-slate-400\" data-kid=\"22\"></i>\n      </div>\n      \n      <div class=\"flex-1 min-w-0\" data-kid=\"23\">\n        <h2 class=\"text-lg font-bold text-(--text-main) name-wrapper\" data-kid=\"24\">\n          سليمان بن عبد الله بن محمد بن إبراهيم الخليل الجار الله\n        </h2>\n        <p class=\"text-xs text-(--text-muted) mt-1\" data-kid=\"25\">المستوى الثالث • سورة البقرة</p>\n      </div>\n\n      <button class=\"btn-minimal px-4 py-2 rounded-lg text-sm font-bold shrink-0\" data-kid=\"26\">\n        التفاصيل\n      </button>\n    </div>\n\n  </div>\n\n  <div class=\"mt-12 text-center\" data-kid=\"27\">\n    <p class=\"text-(--text-muted) text-xs flex items-center justify-center gap-2\" data-kid=\"28\">\n      <i class=\"ti ti-info-circle text-(--accent)\" data-kid=\"29\"></i>\n      تصميم مرن يضمن عدم تداخل الأسماء الطويلة حتى على أصغر الشاشات\n    </p>\n  </div>\n\n</div>",
