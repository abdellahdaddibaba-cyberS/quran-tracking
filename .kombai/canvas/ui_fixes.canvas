      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Tajawal:wght@400;500;700;800;900&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  :root {\n    --bg-primary: #0a0f1e;\n    --bg-card: rgba(17, 24, 39, 0.7);\n    --text-primary: #f1f5f9;\n    --text-secondary: #94a3b8;\n    --gold-500: #f59e0b;\n    --gold-bg: rgba(245, 158, 11, 0.1);\n    --green-500: #22c55e;\n    --green-bg: rgba(34, 197, 94, 0.1);\n    --border: rgba(255, 255, 255, 0.08);\n  }\n\n  body {\n    background-color: var(--bg-primary);\n    color: var(--text-primary);\n    font-family: 'Tajawal', sans-serif;\n    margin: 0;\n    padding: 0;\n    direction: rtl;\n  }\n\n  .glass-card {\n    background: var(--bg-card);\n    backdrop-filter: blur(12px);\n    border: 1px solid var(--border);\n    transition: all 0.3s ease;\n  }\n\n  .glass-card:hover {\n    border-color: var(--gold-500);\n    transform: translateY(-2px);\n    box-shadow: 0 10px 30px -10px rgba(245, 158, 11, 0.2);\n  }\n\n  .line-clamp-2 {\n    display: -webkit-box;\n    -webkit-line-clamp: 2;\n    -webkit-box-orient: vertical;\n    overflow: hidden;\n  }\n</style>\n\n<div class=\"min-h-screen p-8 max-w-6xl mx-auto\" data-kid=\"1\">\n  \n  <div class=\"flex items-center justify-between mb-10\" data-kid=\"2\">\n    <div class=\"flex items-center gap-4\" data-kid=\"3\">\n      <div class=\"w-12 h-12 rounded-xl bg-(--gold-bg) flex items-center justify-center text-(--gold-500)\" data-kid=\"4\">\n        <i class=\"ti ti-users text-2xl\" data-kid=\"5\"></i>\n      </div>\n      <div data-kid=\"6\">\n        <h1 class=\"text-3xl font-black text-(--text-primary)\" data-kid=\"7\">بوابة الأولياء</h1>\n        <p class=\"text-(--text-secondary) text-sm mt-1\" data-kid=\"8\">عرض تفصيلي لمتابعة أبنائكم المسجلين</p>\n      </div>\n    </div>\n\n    \n    <div class=\"bg-(--bg-card) p-1 rounded-lg border border-(--border) flex gap-1\" data-kid=\"9\">\n      <button class=\"px-4 py-2 rounded-md text-(--text-secondary) hover:text-(--text-primary) transition-colors\" data-kid=\"10\">\n        <i class=\"ti ti-layout-list mr-2\" data-kid=\"11\"></i>\n        جدول\n      </button>\n      <button class=\"px-4 py-2 rounded-md bg-(--gold-500) text-white shadow-lg\" data-kid=\"12\">\n        <i class=\"ti ti-layout-grid mr-2\" data-kid=\"13\"></i>\n        بطاقات\n      </button>\n    </div>\n  </div>\n\n  \n  <div class=\"flex flex-col gap-6\" data-kid=\"14\">\n    \n    \n    <div class=\"glass-card rounded-2xl p-6 flex flex-col md:flex-row items-center gap-8\" data-kid=\"15\">\n      \n      <div class=\"relative shrink-0\" data-kid=\"16\">\n        <div class=\"w-24 h-24 rounded-2xl bg-gradient-to-br from-amber-400 to-amber-600 flex items-center justify-center text-3xl font-bold text-white shadow-xl\" data-kid=\"17\">\n          ع\n        </div>\n        <div class=\"absolute -bottom-2 -left-2 bg-green-500 w-6 h-6 rounded-full border-4 border-(--bg-primary)\" data-kid=\"18\"></div>\n      </div>\n\n      \n      <div class=\"flex-1 min-w-0 text-center md:text-right\" data-kid=\"19\">\n        <h2 class=\"text-2xl font-bold text-(--text-primary) mb-3 leading-tight\" data-kid=\"20\">\n          عبد الرحمن بن محمد بن علي بن عثمان آل شيخ التميمي المازني\n        </h2>\n        <div class=\"flex flex-wrap justify-center md:justify-start gap-3\" data-kid=\"21\">\n          <span class=\"px-3 py-1 rounded-full bg-(--gold-bg) text-(--gold-500) text-sm font-bold border border-amber-500/20\" data-kid=\"22\">\n            <i class=\"ti ti-award mr-1\" data-kid=\"23\"></i>\n            المستوى الرابع\n          </span>\n          <span class=\"px-3 py-1 rounded-full bg-blue-500/10 text-blue-400 text-sm font-bold border border-blue-500/20\" data-kid=\"24\">\n            <i class=\"ti ti-book-open mr-1\" data-kid=\"25\"></i>\n            سورة الكهف\n          </span>\n          <span class=\"px-3 py-1 rounded-full bg-purple-500/10 text-purple-400 text-sm font-bold border border-purple-500/20\" data-kid=\"26\">\n            <i class=\"ti ti-calendar mr-1\" data-kid=\"27\"></i>\n            نشط اليوم\n          </span>\n        </div>\n      </div>\n\n      \n      <div class=\"flex gap-8 px-8 border-r border-l border-(--border) hidden lg:flex\" data-kid=\"28\">\n        <div class=\"text-center\" data-kid=\"29\">\n          <div class=\"text-(--text-secondary) text-xs mb-1\" data-kid=\"30\">نسبة الحفظ</div>\n          <div class=\"text-2xl font-black text-(--gold-500)\" data-kid=\"31\">84%</div>\n        </div>\n        <div class=\"text-center\" data-kid=\"32\">\n          <div class=\"text-(--text-secondary) text-xs mb-1\" data-kid=\"33\">الحضور</div>\n          <div class=\"text-2xl font-black text-(--green-500)\" data-kid=\"34\">92%</div>\n        </div>\n      </div>\n\n      \n      <div class=\"flex flex-col gap-3 min-w-[160px]\" data-kid=\"35\">\n        <button class=\"w-full bg-(--gold-500) hover:bg-amber-600 text-white font-bold py-3 rounded-xl transition-colors shadow-lg flex items-center justify-center gap-2\" data-kid=\"36\">\n          <i class=\"ti ti-report-analytics\" data-kid=\"37\"></i>\n          التقرير الكامل\n        </button>\n        <button class=\"w-full border border-(--border) hover:bg-white/5 text-(--text-primary) font-bold py-3 rounded-xl transition-colors flex items-center justify-center gap-2\" data-kid=\"38\">\n          <i class=\"ti ti-message-circle\" data-kid=\"39\"></i>\n          تواصل مع المعلم\n        </button>\n      </div>\n    </div>\n\n    \n    <div class=\"glass-card rounded-2xl p-6 flex flex-col md:flex-row items-center gap-8\" data-kid=\"40\">\n      <div class=\"relative shrink-0\" data-kid=\"41\">\n        <div class=\"w-24 h-24 rounded-2xl bg-gradient-to-br from-emerald-400 to-emerald-600 flex items-center justify-center text-3xl font-bold text-white shadow-xl\" data-kid=\"42\">\n          أ\n        </div>\n      </div>\n\n      <div class=\"flex-1 min-w-0 text-center md:text-right\" data-kid=\"43\">\n        <h2 class=\"text-2xl font-bold text-(--text-primary) mb-3\" data-kid=\"44\">أحمد بن صالح</h2>\n        <div class=\"flex flex-wrap justify-center md:justify-start gap-3\" data-kid=\"45\">\n          <span class=\"px-3 py-1 rounded-full bg-emerald-500/10 text-emerald-400 text-sm font-bold border border-emerald-500/20\" data-kid=\"46\">\n            <i class=\"ti ti-award mr-1\" data-kid=\"47\"></i>\n            المستوى الثاني\n          </span>\n          <span class=\"px-3 py-1 rounded-full bg-blue-500/10 text-blue-400 text-sm font-bold border border-blue-500/20\" data-kid=\"48\">\n            <i class=\"ti ti-book-open mr-1\" data-kid=\"49\"></i>\n            سورة مريم\n          </span>\n        </div>\n      </div>\n\n      <div class=\"flex gap-8 px-8 border-r border-l border-(--border) hidden lg:flex\" data-kid=\"50\">\n        <div class=\"text-center\" data-kid=\"51\">\n          <div class=\"text-(--text-secondary) text-xs mb-1\" data-kid=\"52\">نسبة الحفظ</div>\n          <div class=\"text-2xl font-black text-(--gold-500)\" data-kid=\"53\">45%</div>\n        </div>\n        <div class=\"text-center\" data-kid=\"54\">\n          <div class=\"text-(--text-secondary) text-xs mb-1\" data-kid=\"55\">الحضور</div>\n          <div class=\"text-2xl font-black text-(--green-500)\" data-kid=\"56\">100%</div>\n        </div>\n      </div>\n\n      <div class=\"flex flex-col gap-3 min-w-[160px]\" data-kid=\"57\">\n        <button class=\"w-full bg-(--gold-500) hover:bg-amber-600 text-white font-bold py-3 rounded-xl transition-colors shadow-lg flex items-center justify-center gap-2\" data-kid=\"58\">\n          <i class=\"ti ti-report-analytics\" data-kid=\"59\"></i>\n          التقرير الكامل\n        </button>\n        <button class=\"w-full border border-(--border) hover:bg-white/5 text-(--text-primary) font-bold py-3 rounded-xl transition-colors flex items-center justify-center gap-2\" data-kid=\"60\">\n          <i class=\"ti ti-message-circle\" data-kid=\"61\"></i>\n          تواصل مع المعلم\n        </button>\n      </div>\n    </div>\n\n  </div>\n\n  \n  <div class=\"mt-12 p-6 rounded-2xl border border-dashed border-(--border) flex items-center gap-4 text-(--text-secondary) text-sm\" data-kid=\"62\">\n    <i class=\"ti ti-info-circle text-xl text-(--gold-500)\" data-kid=\"63\"></i>\n    <p data-kid=\"64\">تم تصميم هذا العرض لضمان وضوح الأسماء الطويلة وتجنب تداخل البيانات على الشاشات المختلفة.</p>\n  </div>\n</div>",
