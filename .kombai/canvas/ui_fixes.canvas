ate-200 bg-white text-slate-900 font-bold text-xs text-center outline-none\" data-kid=\"100\">\n                <option value=\"present\" data-kid=\"101\">✅ حاضر</option>\n              </select>\n            </td>\n            <td class=\"px-2 py-4\" data-kid=\"102\">\n              <select class=\"w-full px-2 py-1.5 rounded-lg border border-slate-200 bg-white text-slate-900 font-bold text-xs text-center outline-none\" data-kid=\"103\">\n                <option value=\"present\" data-kid=\"104\">✅ حاضر</option>\n              </select>\n            </td>\n            <td class=\"px-2 py-4\" data-kid=\"105\">\n              <select class=\"w-full px-2 py-1.5 rounded-lg border border-slate-200 bg-white text-slate-900 font-bold text-xs text-center outline-none\" data-kid=\"106\">\n                <option value=\"present\" data-kid=\"107\">✅ حاضر</option>\n              </select>\n            </td>\n            <td class=\"px-2 py-4\" data-kid=\"108\">\n              <select class=\"w-full px-2 py-1.5 rounded-lg border border-slate-200 bg-white text-slate-900 font-bold text-xs text-center outline-none\" data-kid=\"109\">\n                <option value=\"present\" data-kid=\"110\">✅ حاضر</option>\n              </select>\n            </td>\n            <td class=\"px-4 py-4 text-center bg-red-50/20\" data-kid=\"111\">\n              <span class=\"inline-flex items-center justify-center w-7 h-7 rounded-full bg-red-100 text-red-600 font-black text-xs\" data-kid=\"112\">1</span>\n            </td>\n          </tr>\n\n          \n          <tr class=\"hover:bg-slate-50 transition-colors group\" data-kid=\"113\">\n            <td class=\"px-4 py-4 text-center text-slate-400 font-medium\" data-kid=\"114\">3</td>\n            <td class=\"px-4 py-4\" data-kid=\"115\">\n              <div class=\"flex items-center gap-3\" data-kid=\"116\">\n                <div class=\"w-10 h-10 shrink-0 rounded-full bg-blue-100 flex items-center justify-center text-blue-700 font-bold border-2 border-white shadow-sm\" data-kid=\"117\">\n                  م\n                </div>\n                <div class=\"name-column-wrap\" data-kid=\"118\">\n                  <span class=\"name-text\" data-kid=\"119\">محمد علي</span>\n                </div>\n              </div>\n            </td>\n            \n            <td class=\"px-2 py-4\" data-kid=\"120\">\n              <select class=\"w-full px-2 py-1.5 rounded-lg border border-amber-500 bg-amber-50 text-amber-700 font-bold text-xs text-center outline-none\" data-kid=\"121\">\n                <option value=\"late\" data-kid=\"122\">⏱️ متأخر</option>\n              </select>\n            </td>\n            <td class=\"px-2 py-4\" data-kid=\"123\"><select class=\"w-full px-2 py-1.5 rounded-lg border border-slate-200 bg-white text-slate-900 font-bold text-xs text-center outline-none\" data-kid=\"124\"><option value=\"present\" data-kid=\"125\">✅ حاضر</option></select></td>\n            <td class=\"px-2 py-4\" data-kid=\"126\"><select class=\"w-full px-2 py-1.5 rounded-lg border border-slate-200 bg-white text-slate-900 font-bold text-xs text-center outline-none\" data-kid=\"127\"><option value=\"present\" data-kid=\"128\">✅ حاضر</option></select></td>\n            <td class=\"px-2 py-4\" data-kid=\"129\"><select class=\"w-full px-2 py-1.5 rounded-lg border border-slate-200 bg-white text-slate-900 font-bold text-xs text-center outline-none\" data-kid=\"130\"><option value=\"present\" data-kid=\"131\">✅ حاضر</option></select></td>\n            <td class=\"px-2 py-4\" data-kid=\"132\"><select class=\"w-full px-2 py-1.5 rounded-lg border border-slate-200 bg-white text-slate-900 font-bold text-xs text-center outline-none\" data-kid=\"133\"><option value=\"present\" data-kid=\"134\">✅ حاضر</option></select></td>\n            <td class=\"px-2 py-4\" data-kid=\"135\"><select class=\"w-full px-2 py-1.5 rounded-lg border border-slate-200 bg-white text-slate-900 font-bold text-xs text-center outline-none\" data-kid=\"136\"><option value=\"present\" data-kid=\"137\">✅ حاضر</option></select></td>\n            <td class=\"px-4 py-4 text-center bg-red-50/20\" data-kid=\"138\">\n              <span class=\"inline-flex items-center justify-center w-7 h-7 rounded-full bg-slate-100 text-slate-400 font-bold text-xs\" data-kid=\"139\">0</span>\n            </td>\n          </tr>\n        </tbody>\n      </table>\n    </div>\n  </div>\n\n  \n  <div class=\"mt-8 flex items-center gap-3 text-slate-500 text-sm bg-slate-100/50 p-4 rounded-xl border border-slate-200/60\" data-kid=\"140\">\n    <i class=\"ti ti-info-circle text-lg text-slate-400\" data-kid=\"141\"></i>\n    <span data-kid=\"142\">تستخدم هذه الواجهة تقنية <strong data-kid=\"143\">\"Controlled Wrapping\"</strong> لضمان ثبات عرض الأعمدة حتى مع الأسماء الطويلة جداً، مع الحفاظ على وضوح الخط وسهولة القراءة.</span>\n  </div>\n</div>",
