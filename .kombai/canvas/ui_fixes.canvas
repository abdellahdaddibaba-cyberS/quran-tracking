      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Tajawal:wght@400;500;700;800;900&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  :root {\n    --bg-primary: #0a0f1e;\n    --bg-card: rgba(17, 24, 39, 0.7);\n    --text-primary: #f1f5f9;\n    --text-secondary: #94a3b8;\n    --gold-500: #f59e0b;\n    --gold-bg: rgba(245, 158, 11, 0.1);\n    --green-500: #22c55e;\n    --green-bg: rgba(34, 197, 94, 0.1);\n    --border: rgba(255, 255, 255, 0.08);\n  }\n\n  body {\n    background-color: var(--bg-primary);\n    color: var(--text-primary);\n    font-family: 'Tajawal', sans-serif;\n    margin: 0;\n    padding: 0;\n    direction: rtl;\n  }\n\n  .glass-card {\n    background: var(--bg-card);\n    backdrop-filter: blur(12px);\n    border: 1px solid var(--border);\n    transition: all 0.3s ease;\n  }\n\n  .glass-card:hover {\n    border-color: var(--gold-500);\n    transform: translateY(-4px);\n    box-shadow: 0 15px 40px -15px rgba(245, 158, 11, 0.25);\n  }\n\n  .progress-ring {\n    transform: rotate(-90deg);\n  }\n</style>\n\n<div class=\"min-h-screen p-8 max-w-7xl mx-auto\" data-kid=\"1\">\n  \n  <div class=\"flex items-center justify-between mb-12\" data-kid=\"2\">\n    <div class=\"flex items-center gap-5\" data-kid=\"3\">\n      <div class=\"w-14 h-14 rounded-2xl bg-(--gold-bg) flex items-center justify-center text-(--gold-500)\" data-kid=\"4\">\n        <i class=\"ti ti-layout-grid text-3xl\" data-kid=\"5\"></i>\n      </div>\n      <div data-kid=\"6\">\n        <h1 class=\"text-3xl font-black text-(--text-primary)\" data-kid=\"7\">بوابة الأولياء - عرض الشبكة</h1>\n        <p class=\"text-(--text-secondary) mt-1\" data-kid=\"8\">متابعة دقيقة للأبناء بنظام البطاقات المفصلة</p>\n      </div>\n    </div>\n\n    <div class=\"bg-(--bg-card) p-1 rounded-xl border border-(--border) flex gap-1\" data-kid=\"9\">\n      <button class=\"px-5 py-2.5 rounded-lg text-(--text-secondary) hover:text-(--text-primary) transition-colors flex items-center gap-2\" data-kid=\"10\">\n        <i class=\"ti ti-layout-list text-lg\" data-kid=\"11\"></i>\n        جدول\n      </button>\n      <button class=\"px-5 py-2.5 rounded-lg bg-(--gold-500) text-white shadow-lg flex items-center gap-2\" data-kid=\"12\">\n        <i class=\"ti ti-layout-grid text-lg\" data-kid=\"13\"></i>\n        بطاقات مفصلة\n      </button>\n    </div>\n  </div>\n\n  \n  <div class=\"grid grid-cols-1 md:grid-cols-2 gap-8\" data-kid=\"14\">\n    \n    \n    <div class=\"glass-card rounded-3xl p-7 flex flex-col gap-6\" data-kid=\"15\">\n      <div class=\"flex items-start gap-5\" data-kid=\"16\">\n        <div class=\"relative shrink-0\" data-kid=\"17\">\n          <div class=\"w-20 h-20 rounded-2xl bg-gradient-to-br from-amber-400 to-amber-600 flex items-center justify-center text-3xl font-bold text-white shadow-xl\" data-kid=\"18\">\n            ع\n          </div>\n          <div class=\"absolute -bottom-1 -left-1 bg-green-500 w-5 h-5 rounded-full border-4 border-(--bg-primary)\" data-kid=\"19\"></div>\n        </div>\n        <div class=\"flex-1\" data-kid=\"20\">\n          <div class=\"flex justify-between items-start mb-2\" data-kid=\"21\">\n            <span class=\"px-3 py-1 rounded-full bg-(--gold-bg) text-(--gold-500) text-xs font-bold border border-amber-500/20\" data-kid=\"22\">المستوى الرابع</span>\n            <span class=\"text-(--text-secondary) text-xs\" data-kid=\"23\">نشط منذ ساعتين</span>\n          </div>\n          <h2 class=\"text-xl font-bold text-(--text-primary) leading-snug\" data-kid=\"24\">عبد الرحمن بن محمد بن علي بن عثمان آل شيخ التميمي المازني</h2>\n        </div>\n      </div>\n\n      <div class=\"grid grid-cols-2 gap-4\" data-kid=\"25\">\n        <div class=\"bg-white/5 p-4 rounded-2xl border border-white/5\" data-kid=\"26\">\n          <div class=\"text-(--text-secondary) text-xs mb-2\" data-kid=\"27\">السورة الحالية</div>\n          <div class=