ass=\"flex items-center gap-10 px-8 border-slate-100 lg:border-r lg:border-l w-full lg:w-auto justify-between lg:justify-start py-4 lg:py-0\" data-kid=\"60\">\n        <div class=\"w-32\" data-kid=\"61\">\n          <div class=\"flex justify-between items-center mb-1.5\" data-kid=\"62\">\n            <span class=\"text-[11px] font-bold text-slate-400\" data-kid=\"63\">تحصيل الحفظ</span>\n            <span class=\"text-xs font-black text-emerald-600\" data-kid=\"64\">45%</span>\n          </div>\n          <div class=\"h-2 w-full progress-bar-bg rounded-full overflow-hidden\" data-kid=\"65\">\n            <div class=\"h-full progress-bar-fill w-[45%] rounded-full\" data-kid=\"66\"></div>\n          </div>\n        </div>\n\n        <div class=\"w-32\" data-kid=\"67\">\n          <div class=\"flex justify-between items-center mb-1.5\" data-kid=\"68\">\n            <span class=\"text-[11px] font-bold text-slate-400\" data-kid=\"69\">نسبة الحضور</span>\n            <span class=\"text-xs font-black text-blue-600\" data-kid=\"70\">100%</span>\n          </div>\n          <div class=\"h-2 w-full progress-bar-bg rounded-full overflow-hidden\" data-kid=\"71\">\n            <div class=\"h-full bg-blue-500 w-[100%] rounded-full\" data-kid=\"72\"></div>\n          </div>\n        </div>\n      </div>\n\n      <div class=\"flex items-center gap-3 w-full lg:w-auto shrink-0\" data-kid=\"73\">\n        <button class=\"flex-1 lg:flex-none px-6 py-3 bg-emerald-600 hover:bg-emerald-700 text-white font-bold rounded-xl transition-all shadow-md flex items-center justify-center gap-2\" data-kid=\"74\">\n          <i class=\"ti ti-chart-bar\" data-kid=\"75\"></i>\n          التقرير الكامل\n        </button>\n        <button class=\"flex-1 lg:flex-none p-3 bg-slate-50 hover:bg-slate-100 text-slate-600 rounded-xl border border-slate-200 transition-all flex items-center justify-center\" data-kid=\"76\">\n          <i class=\"ti ti-messages text-xl\" data-kid=\"77\"></i>\n        </button>\n      </div>\n    </div>\n\n  </div>\n\n  \n  <div class=\"mt-8 bg-emerald-50/50 rounded-2xl p-4 border border-emerald-100 flex items-center gap-3 text-emerald-800\" data-kid=\"78\">\n    <i class=\"ti ti-info-circle text-xl shrink-0\" data-kid=\"79\"></i>\n    <p class=\"text-sm font-medium\" data-kid=\"80\">يتم تحديث نسب التحصيل والحضور يومياً بعد كل حلقة. في حال وجود أي استفسار يرجى التواصل مع المشرف مباشرة عبر نظام المراسلة.</p>\n  </div>\n</div>",
