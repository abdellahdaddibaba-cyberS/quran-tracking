      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Tajawal:wght@400;500;700;800;900&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  .font-tajawal {\n    font-family: 'Tajawal', sans-serif;\n  }\n\n  /* Fixed wrapping strategy for long names */\n  .name-column-wrap {\n    max-width: 240px;\n    display: -webkit-box;\n    -webkit-line-clamp: 2;\n    -webkit-box-orient: vertical;\n    overflow: hidden;\n    line-height: 1.25;\n  }\n\n  /* Simulate hierarchy: Larger first line, slightly smaller subsequent lines */\n  .name-text::first-line {\n    font-size: 0.9375rem; /* ~15px */\n    font-weight: 700;\n    color: #0f172a; /* slate-900 */\n  }\n  \n  .name-text {\n    font-size: 0.8125rem; /* ~13px */\n    color: #64748b; /* slate-500 */\n    font-weight: 500;\n  }\n\n  .table-container {\n    box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1);\n  }\n</style>\n\n<div class=\"font-tajawal bg-[#f8fafc] min-h-screen p-8\" dir=\"rtl\" data-kid=\"1\">\n  \n  <div class=\"flex items-center justify-between mb-8\" data-kid=\"2\">\n    <div class=\"flex items-center gap-4\" data-kid=\"3\">\n      <div class=\"w-12 h-12 rounded-xl bg-emerald-100 flex items-center justify-center text-emerald-600 shadow-sm\" data-kid=\"4\">\n        <i class=\"ti ti-user-check text-2xl\" data-kid=\"5\"></i>\n      </div>\n      <div data-kid=\"6\">\n        <h1 class=\"text-2xl font-black text-slate-900 leading-none mb-1\" data-kid=\"7\">سجل الحضور الأسبوعي</h1>\n        <p class=\"text-slate-500 text-sm\" data-kid=\"8\">متابعة حضور الطلاب وتحصيلهم اليومي</p>\n      </div>\n    </div>\n    \n    <button class=\"bg-emerald-600 hover:bg-emerald-700 text-white px-6 py-3 rounded-xl font-bold flex items-center gap-2 transition-all shadow-lg shadow-emerald-200\" data-kid=\"9\">\n      <i class=\"ti ti-device-floppy text-lg\" data-kid=\"10\"></i>\n      <span data-kid=\"11\">حفظ سجل الحضور</span>\n    </button>\n  </div>\n\n  \n  <div class=\"bg-white rounded-2xl p-6 mb-6 shadow-sm border border-slate-100 flex flex-wrap gap-6 items-end\" data-kid=\"12\">\n    <div class=\"flex-1 min-w-[300px]\" data-kid=\"13\">\n      <label class=\"block text-sm font-bold text-slate-700 mb-2\" data-kid=\"14\">تاريخ الأسبوع</label>\n      <div class=\"flex items-center gap-3\" data-kid=\"15\">\n        <button class=\"p-2 rounded-lg border border-slate-200 hover:bg-slate-50 text-slate-600 transition-colors\" data-kid=\"16\">\n          <i class=\"ti ti-chevron-right text-lg\" data-kid=\"17\"></i>\n        </button>\n        <div class=\"relative flex-1\" data-kid=\"18\">\n          <i class=\"ti ti-calendar text-slate-400 absolute right-3 top-1/2 -translate-y-1/2\" data-kid=\"19\"></i>\n          <input type=\"text\" value=\"الأسبوع الثاني (20 - 25 يونيو 2026)\" readonly class=\"w-full pr-10 pl-4 py-2.5 bg-slate-50 border border-slate-200 rounded-lg text-slate-900 font-medium text-center focus:ring-2 focus:ring-emerald-500/20 focus:border-emerald-500 outline-none transition-all\" data-kid=\"20\">\n        </div>\n        <button class=\"p-2 rounded-lg border border-slate-200 hover:bg-slate-50 text-slate-600 transition-colors\" data-kid=\"21\">\n          <i class=\"ti ti-chevron-left text-lg\" data-kid=\"22\"></i>\n        </button>\n      </div>\n    </div>\n\n    <div class=\"flex-1 min-w-[300px]\" data-kid=\"23\">\n      <label class=\"block text-sm font-bold text-slate-700 mb-2\" data-kid=\"24\">البحث عن طالب</label>\n      <div class=\"relative\" data-kid=\"25\">\n        <i class=\"ti ti-search text-slate-400 absolute right-3 top-1/2 -translate-y-1/2\" data-kid=\"26\"></i>\n        <input type=\"text\" placeholder=\"اكتب اسم الطالب للبحث...\" class=\"w-full pr-10 pl-4 py-2.5 border border-slate-200 rounded-lg text-slate-900 focus:ring-2 focus:ring-emerald-500/20 focus:border-emerald-500 outline-none transition-all placeholder:text-slate-400\" data-kid=\"27\">\n      </div>\n    </div>\n  </div>\n\n  \n  <div class=\"bg-white rounded-2xl border border-slate-100 overflow-hidden shadow-sm\" data-kid=\"28\">\n    <div class=\"overflow-x-auto\" data-kid=\"29\">\n      <table class=\"w-full text-right border-collapse\" data-kid=\"30\">\n        <thead data-kid=\"31\">\n          <tr class=\"bg-slate-50 border-b border-slate-100\" data-kid=\"32\">\n            <th class=\"px-4 py-4 text-xs font-bold text-slate-500 uppercase tracking-wider w-12 text-center\" data-kid=\"33\">#</th>\n            <th class=\"px-4 py-4 text-xs font-bold text-slate-500 uppercase tracking-wider min-w-[280px]\" data-kid=\"34\">اسم الطالب</th>\n            <th class=\"px-4 py-4 text-xs font-bold text-slate-500 uppercase tracking-wider text-center\" data-kid=\"35\">السبت</th>\n            <th class=\"px-4 py-4 text-xs font-bold text-slate-500 uppercase tracking-wider text-center\" data-kid=\"36\">الأحد</th>\n            <th class=\"px-4 py-4 text-xs font-bold text-slate-500 uppercase tracking-wider text-center\" data-kid=\"37\">الاثنين</th>\n            <th class=\"px-4 py-4 text-xs font-bold text-slate-500 uppercase tracking-wider text-center\" data-kid=\"38\">الثلاثاء</th>\n            <th class=\"px-4 py-4 text-xs font-bold text-slate-500 uppercase tracking-wider text-center\" data-kid=\"39\">الأربعاء</th>\n            <th class=\"px-4 py-4 text-xs font-bold text-slate-500 uppercase tracking-wider text-center\" data-kid=\"40\">الخميس</th>\n            <th class=\"px-4 py-4 text-xs font-bold text-slate-500 uppercase tracking-wider text-center bg-red-50/50 text-red-600\" data-kid=\"41\">الغياب</th>\n          </tr>\n        </thead>\n        <tbody class=\"divide-y divide-slate-100\" data-kid=\"42\">\n          \n          <tr class=\"hover:bg-slate-50 transition-colors group\" data-kid=\"43\">\n            <td class=\"px-4 py-4 text-center text-slate-400 font-medium\" data-kid=\"44\">1</td>\n            <td class=\"px-4 py-4\" data-kid=\"45\">\n              <div class=\"flex items-center gap-3\" data-kid=\"46\">\n                <div class=\"w-10 h-10 shrink-0 rounded-full bg-indigo-100 flex items-center justify-center text-indigo-700 font-bold border-2 border-white shadow-sm\" data-kid=\"47\">\n                  أ\n                </div>\n                <div class=\"name-column-wrap\" data-kid=\"48\">\n                  <span class=\"name-text\" data-kid=\"49\">أحمد عبد الرحمن محمد دادي بابا السعدي بن عمر الخطاب</span>\n                </div>\n              </div>\n            </td>\n            \n            <td class=\"px-2 py-4\" data-kid=\"50\">\n              <select class=\"w-full px-2 py-1.5 rounded-lg border border-emerald-500 bg-emerald-50 text-emerald-700 font-bold text-xs text-center outline-none cursor-pointer hover:border-emerald-600 transition-all\" data-kid=\"51\">\n                <option value=\"present\" data-kid=\"52\">✅ حاضر</option>\n                <option value=\"absent\" data-kid=\"53\">❌ غائب</option>\n                <option value=\"late\" data-kid=\"54\">⏱️ متأخر</option>\n              </select>\n            </td>\n            <td class=\"px-2 py-4\" data-kid=\"55\">\n              <select class=\"w-full px-2 py-1.5 rounded-lg border border-slate-200 bg-white text-slate-900 font-bold text-xs text-center outline-none cursor-pointer hover:border-emerald-500 transition-all\" data-kid=\"56\">\n                <option value data-kid=\"57\">— اختر —</option>\n                <option value=\"present\" data-kid=\"58\">✅ حاضر</option>\n                <option value=\"absent\" data-kid=\"59\">❌ غائب</option>\n                <option value=\"late\" data-kid=\"60\">⏱️ متأخر</option>\n              </select>\n            </td>\n            <td class=\"px-2 py-4\" data-kid=\"61\">\n              <select class=\"w-full px-2 py-1.5 rounded-lg border border-slate-200 bg-white text-slate-900 font-bold text-xs text-center outline-none cursor-pointer hover:border-emerald-500 transition-a