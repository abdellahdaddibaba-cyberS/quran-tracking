      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Tajawal:wght@400;500;700;800;900&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  body {\n    font-family: 'Tajawal', sans-serif;\n    background-color: #f8fafc;\n    color: #0f172a;\n    direction: rtl;\n    margin: 0;\n    padding: 2rem;\n  }\n\n  .card-shadow {\n    box-shadow: 0 1px 3px 0 rgba(0, 0, 0, 0.1), 0 1px 2px -1px rgba(0, 0, 0, 0.1);\n  }\n\n  .card-hover:hover {\n    box-shadow: 0 10px 15px -3px rgba(16, 185, 129, 0.1), 0 4px 6px -4px rgba(16, 185, 129, 0.1);\n    border-color: #10b981;\n  }\n\n  .progress-bar-bg {\n    background-color: #e2e8f0;\n  }\n\n  .progress-bar-fill {\n    background-color: #10b981;\n  }\n</style>\n\n<div class=\"max-w-6xl mx-auto\" data-kid=\"1\">\n  \n  <div class=\"flex items-center justify-between mb-10 bg-white p-6 rounded-2xl shadow-sm border border-slate-200\" data-kid=\"2\">\n    <div class=\"flex items-center gap-5\" data-kid=\"3\">\n      <div class=\"w-14 h-14 rounded-2xl bg-emerald-100 flex items-center justify-center text-emerald-600\" data-kid=\"4\">\n        <i class=\"ti ti-smart-home text-3xl\" data-kid=\"5\"></i>\n      </div>\n      <div data-kid=\"6\">\n        <h1 class=\"text-2xl font-black text-slate-900 leading-tight\" data-kid=\"7\">بوابة الأولياء</h1>\n        <p class=\"text-slate-500 text-sm font-medium\" data-kid=\"8\">نظام المتابعة التربوية والتحصيل العلمي</p>\n      </div>\n    </div>\n    \n    <div class=\"flex items-center gap-3\" data-kid=\"9\">\n      <div class=\"text-left ml-4 hidden md:block\" data-kid=\"10\">\n        <div class=\"text-xs text-slate-400 font-bold uppercase tracking-wider\" data-kid=\"11\">الحساب الحالي</div>\n        <div class=\"text-sm font-bold text-slate-700\" data-kid=\"12\">ولي الأمر: محمد العتيبي</div>\n      </div>\n      <img src=\"https://i.pravatar.cc/100?u=parent\" class=\"w-12 h-12 rounded-full border-2 border-emerald-500 p-0.5\" alt=\"Avatar\" data-kid=\"13\">\n    </div>\n  </div>\n\n  \n  <div class=\"space-y-4\" data-kid=\"14\">\n    \n    \n    <div class=\"bg-white rounded-2xl p-5 border border-slate-200 flex flex-col lg:flex-row items-center gap-8 card-shadow card-hover transition-all duration-300\" data-kid=\"15\">\n      \n      \n      <div class=\"flex items-center gap-5 flex-1 min-w-0 w-full lg:w-auto\" data-kid=\"16\">\n        <div class=\"relative group shrink-0\" data-kid=\"17\">\n          <div class=\"w-20 h-20 rounded-2xl bg-emerald-500 flex items-center justify-center text-2xl font-black text-white shadow-lg overflow-hidden\" data-kid=\"18\">\n            <img src=\"https://i.pravatar.cc/150?u=stu1\" class=\"w-full h-full object-cover\" alt=\"Student\" data-kid=\"19\">\n          </div>\n          <div class=\"absolute -bottom-1 -right-1 w-6 h-6 bg-emerald-500 rounded-full border-4 border-white flex items-center justify-center\" data-kid=\"20\">\n            <i class=\"ti ti-check text-[10px] text-white\" data-kid=\"21\"></i>\n          </div>\n        </div>\n        \n        <div class=\"flex-1 min-w-0\" data-kid=\"22\">\n          <h2 class=\"text-xl font-extrabold text-slate-900 leading-tight mb-1 truncate group-hover:whitespace-normal transition-all\" title=\"عبد الرحمن بن محمد بن علي بن عثمان آل شيخ التميمي المازني\" data-kid=\"23\">\n            عبد الرحمن بن محمد بن علي بن عثمان آل شيخ التميمي المازني\n          </h2>\n          <div class=\"flex flex-wrap gap-2\" data-kid=\"24\">\n            <span class=\"inline-flex items-center gap-1.5 px-2.5 py-0.5 rounded-md bg-emerald-50 text-emerald-700 text-xs font-bold border border-emerald-100\" data-kid=\"25\">\n              <i class=\"ti ti-school\" data-kid=\"26\"></i> المستوى الرابع\n            </span>\n            <span class=\"inline-flex items-center gap-1.5 px-2.5 py-0.5 rounded-md bg-blue-50 text-blue-700 text-xs font-bold border border-blue-100\" data-kid=\"27\">\n              <i class=\"ti ti-book\" data-kid=\"28\"></i> سورة الكهف\n            </span>\n          </div>\n        </div>\n      </div>\n\n      \n      <div class=\"flex items-center gap-10 px-8 border-slate-100 lg:border-r lg:border-l w-full lg:w-auto justify-between lg:justify-start py-4 lg:py-0\" data-kid=\"29\">\n        <div class=\"w-32\" data-kid=\"30\">\n          <div class=\"flex justify-between items-center mb-1.5\" data-kid=\"31\">\n            <span class=\"text-[11px] font-bold text-slate-400\" data-kid=\"32\">تحصيل الحفظ</span>\n            <span class=\"text-xs font-black text-emerald-600\" data-kid=\"33\">84%</span>\n          </div>\n          <div class=\"h-2 w-full progress-bar-bg rounded-full overflow-hidden\" data-kid=\"34\">\n            <div class=\"h-full progress-bar-fill w-[84%] rounded-full shadow-[0_0_8px_rgba(16,185,129,0.3)]\" data-kid=\"35\"></div>\n          </div>\n        </div>\n\n        <div class=\"w-32\" data-kid=\"36\">\n          <div class=\"flex justify-between items-center mb-1.5\" data-kid=\"37\">\n            <span class=\"text-[11px] font-bold text-slate-400\" data-kid=\"38\">نسبة الحضور</span>\n            <span class=\"text-xs font-black text-blue-600\" data-kid=\"39\">92%</span>\n          </div>\n          <div class=\"h-2 w-full progress-bar-bg rounded-full overflow-hidden\" data-kid=\"40\">\n            <div class=\"h-full bg-blue-500 w-[92%] rounded-full shadow-[0_0_8px_rgba(59,130,246,0.3)]\" data-kid=\"41\"></div>\n          </div>\n        </div>\n      </div>\n\n      \n      <div class=\"flex items-center gap-3 w-full lg:w-auto shrink-0\" data-kid=\"42\">\n        <button class=\"flex-1 lg:flex-none px-6 py-3 bg-emerald-600 hover:bg-emerald-700 text-white font-bold rounded-xl transition-all shadow-md active:scale-95 flex items-center justify-center gap-2\" data-kid=\"43\">\n          <i class=\"ti ti-chart-bar\" data-kid=\"44\"></i>\n          التقرير الكامل\n        </button>\n        <button class=\"flex-1 lg:flex-n