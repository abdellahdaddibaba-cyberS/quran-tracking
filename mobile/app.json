{
  "expo": {
    "name": "تحصيلي",
    "slug": "qurantrackingannour",
    "version": "1.0.2",
    "supportsRTL": false,
    "orientation": "portrait",
    "icon": "./assets/images/square logo.png",
    "scheme": "mobile",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.qurancenter.tracking",
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "POST_NOTIFICATIONS",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "POST_NOTIFICATIONS",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/square logo.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-updates",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/Logo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "image": "./assets/images/Logo.png",
            "backgroundColor": "#0f172a"
          }
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/square logo.png",
          "color": "#22c55e",
          "defaultChannel": "default",
          "enableBackgroundRemoteNotifications": true
        }
      ],
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "apiUrl": "https://quran-tracking-api.onrender.com/api",
      "serverRoot": "https://quran-tracking-api.onrender.com",
      "router": {},
      "eas": {
        "projectId": "0d9685bc-48ed-4b29-80e0-3d1493ef896d"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "owner": "abdellahdaddis-organization",
    "updates": {
      "url": "https://u.expo.dev/0d9685bc-48ed-4b29-80e0-3d1493ef896d",
      "checkAutomatically": "ON_LOAD",
      "enabled": true
    }
  }
}
