# Server
PORT=5000
NODE_ENV=development

# PostgreSQL (local — بدون SSL)
PG_SSL=false
PG_HOST=localhost
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=your_password
PG_DB=quran_tracking

# Auth (required in production)
JWT_SECRET=change_me_to_a_long_random_string

# Optional: restrict web origins in production (comma-separated)
# CORS_ORIGINS=https://your-frontend.onrender.com,http://localhost:3000

# Optional: enable Sequelize alter sync in development (default: off)
# PG_SYNC_ALTER=true

# على Render/Supabase أضف: NODE_ENV=production و PG_SSL=true

# Optional: Supabase sync (npm run sync)
# SUPABASE_DB_URL=postgresql://postgres:password@db.xxxx.supabase.co:5432/postgres

# ─── LLM (AI Suggestion) — one provider is enough ─────────────────
# OpenAI or any OpenAI-compatible API (Groq, DeepSeek, etc.)
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini

# Or Google Gemini (if set, takes priority over OpenAI)
# GEMINI_API_KEY=your_gemini_api_key
# GEMINI_MODEL=gemini-2.0-flash
